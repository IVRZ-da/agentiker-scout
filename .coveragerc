[run]
source = /home/jo/.hermes/plugins/scout
relative_files = True
omit = tests/*, scripts/*, .hermes/*

[paths]
source =
    /home/jo/.hermes/plugins/scout
    .

[report]
exclude_lines =
    pragma: no cover
    def __repr__
    if __name__ == .__main__.:
    raise AssertionError
    raise NotImplementedError
show_missing = True
