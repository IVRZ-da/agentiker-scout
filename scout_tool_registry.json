      "name": "research_search",
      "handler_module": "scout.research.tools.search",
      "handler_name": "research_search",
      "schema": {
        "name": "research_search",
        "description": "Search saved research results.",
        "parameters": {
          "type": "object",
          "properties": {
            "query": {
              "type": "string",
              "description": "Search query."
            },
            "limit": {
              "type": "integer",
              "description": "Max results 1-50.",
              "default": 5,
              "minimum": 1,
              "maximum": 50
            },
            "tags": {
              "type": "array",
              "items": {
                "type": "string"
              },
              "description": "Tags filter."
            },
            "status": {
              "type": "string",
              "description": "Status filter."
            },
            "date_from": {
              "type": "string",
