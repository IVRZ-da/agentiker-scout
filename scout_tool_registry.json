        "description": "Verify source URLs and findings.",
        "parameters": {
          "type": "object",
          "properties": {
            "research_id": {
              "type": "string",
              "description": "Research ID."
            }
          },
          "required": [
            "research_id"
          ]
        }
      }
    },
    {
      "name": "research_auto",
      "handler_module": "scout.research.tools.crud",
      "handler_name": "research_auto",
      "schema": {
        "name": "research_auto",
        "description": "Autonomous web research agent.",
        "parameters": {
          "type": "object",
          "properties": {
            "query": {
              "type": "string",
              "description": "Research query."
            },
            "depth": {
              "type": "integer",
              "description": "Depth (1-5).",
              "default": 3,
              "minimum": 1,
              "maximum": 5
            },
            "max_sources": {
              "type": "integer",
              "description": "Max sources (1-20).",
