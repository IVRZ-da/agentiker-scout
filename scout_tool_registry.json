        "parameters": {
          "type": "object",
          "properties": {
            "action": {
              "type": "string",
              "enum": [
                "plans",
                "all"
              ],
              "description": "Cleanup action.",
              "default": "plans"
            },
            "older_than_days": {
              "type": "integer",
              "description": "Age in days.",
              "default": 30,
              "minimum": 1
            }
          }
        }
      }
    },
    {
      "name": "research_tag",
      "handler_module": "scout.research.tools.crud",
      "handler_name": "research_tag",
      "schema": {
        "name": "research_tag",
        "description": "Manage tags for a research session.",
        "parameters": {
          "type": "object",
          "properties": {
            "research_id": {
              "type": "string",
              "description": "Research ID."
            },
            "tags": {
              "type": "array",
              "items": {
                "type": "string"
              },
              "description": "Tags to manage."
            },
            "action": {
              "type": "string",
              "enum": [
                "add",
                "remove",
                "set",
                "clear"
              ],
              "description": "Tag action.",
              "default": "add"
            }
          },
          "required": [
            "research_id",
            "tags"
          ]
        }
      }
    },
    {
      "name": "research_update",
      "handler_module": "scout.research.tools.crud",
      "handler_name": "research_update",
      "schema": {
        "name": "research_update",
        "description": "Update existing research data.",
        "parameters": {
          "type": "object",
          "properties": {
            "research_id": {
              "type": "string",
              "description": "Research ID."
            },
            "summary": {
              "type": "string",
              "description": "Updated summary."
            },
            "status": {
              "type": "string",
              "enum": [
                "completed",
                "partial",
                "failed"
              ],
              "description": "Updated status."
            },
            "append_findings": {
              "type": "array",
              "items": {
                "type": "object"
              },
              "description": "Append findings."
            },
            "append_sources": {
              "type": "array",
              "items": {
                "type": "object"
              },
              "description": "Append sources."
            }
          },
          "required": [
            "research_id"
          ]
        }
      }
    },
    {
      "name": "research_verify",
      "handler_module": "scout.research.tools.crud",
