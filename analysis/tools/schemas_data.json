{
  "ANALYSIS_ARCHITECTURE_SCHEMA": {
    "name": "analysis_architecture",
    "description": "Full architecture analysis: structure, dependencies, cycles, hotspots.",
    "parameters": {
      "type": "object",
      "properties": {
        "path": {
          "type": "string",
          "description": "Project root path."
        },
        "format": {
          "type": "string",
          "enum": [
            "text",
            "mermaid",
            "json"
          ],
          "description": "Format: text or json.",
          "default": "text"
        },
        "depth": {
          "type": "integer",
          "description": "Depth (1-3).",
          "default": 2,
          "minimum": 1,
          "maximum": 3
        }
      },
      "required": [
        "path"
      ]
    }
  },
  "ANALYSIS_ASK_SCHEMA": {
    "name": "analysis_ask",
    "description": "Ask a natural language question about code.",
    "parameters": {
      "type": "object",
      "properties": {
        "question": {
          "type": "string",
          "description": "A natural language question about the code."
        },
        "path": {
          "type": "string",
          "description": "Optional path for context."
        }
      },
      "required": [
        "question"
      ]
    }
  },
  "ANALYSIS_CODE_MOVE_SCHEMA": {
    "name": "analysis_code_move",
    "description": "Move a symbol between files via AST extraction.",
    "parameters": {
      "type": "object",
      "properties": {
        "source": {
          "type": "string",
          "description": "Source file path"
        },
        "symbol": {
          "type": "string",
          "description": "Symbol name to move"
        },
        "target": {
          "type": "string",
          "description": "Target file path"
        },
        "dry_run": {
          "type": "boolean",
          "description": "Dry run (default: True)"
        }
      },
      "required": [
        "source",
        "symbol",
        "target"
      ]
    }
  },
  "ANALYSIS_CODE_QUERY_SCHEMA": {
    "name": "analysis_code_query",
    "description": "Smart query router for code intelligence.",
    "parameters": {
      "type": "object",
      "properties": {
        "intent": {
          "type": "string",
          "description": "Intent: find_usage, definition, understand, etc."
        },
        "path": {
          "type": "string",
          "description": "File or directory path."
        },
        "line": {
          "type": "integer",
          "description": "Line number (1-based)."
        },
        "language": {
          "type": "string",
          "description": "Language override."
        }
      },
      "required": [
        "intent"
      ]
    }
  },
  "ANALYSIS_DEADCODE_SCHEMA": {
    "name": "analysis_deadcode",
    "description": "Find unused imports, functions, and error handlers.",
    "parameters": {
      "type": "object",
      "properties": {
        "path": {
          "type": "string",
          "description": "Absolute path to file or directory to scan."
        },
        "kinds": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "imports",
              "functions",
              "errors",
              "all"
            ]
          },
          "description": "Dead code types: imports, functions, errors, all.",
          "default": [
            "all"
          ]
        },
        "persist": {
          "type": "boolean",
          "description": "Persist results in Honcho (default: true).",
          "default": true
        },
        "max_files": {
          "type": "integer",
          "description": "Max files (default: 500).",
          "default": 500
        },
        "timeout": {
          "type": "integer",
          "description": "Timeout in seconds (default: 60).",
          "default": 60
        }
      },
      "required": [
        "path"
      ]
    }
  },
  "ANALYSIS_DEPENDENCY_RISK_SCHEMA": {
    "name": "analysis_dependency_risk",
    "description": "Evaluate dependency risk with weighted score.",
    "parameters": {
      "type": "object",
      "properties": {
        "path": {
          "type": "string",
          "description": "Absolute file or directory path."
        },
        "detail_level": {
          "type": "string",
          "enum": [
            "summary",
            "detailed"
          ],
          "description": "'summary' (default) gibt Gesamt-Score, 'detailed' zeigt Breakdown.",
          "default": "summary"
        }
      },
      "required": [
        "path"
      ]
    }
  },
  "ANALYSIS_DIFF_ANALYSIS_SCHEMA": {
    "name": "analysis_diff_analysis",
    "description": "Compare git refs, show changed functions and impact.",
    "parameters": {
      "type": "object",
      "properties": {
        "path": {
          "type": "string",
          "description": "Absolute path to git repository."
        },
        "base": {
          "type": "string",
          "description": "Base ref (default: main).",
          "default": "main"
        },
        "head": {
          "type": "string",
          "description": "Head ref (default: HEAD).",
          "default": "HEAD"
        },
        "max_files": {
          "type": "integer",
          "description": "Max files (default: 5).",
          "default": 5
        }
      },
      "required": [
        "path"
      ]
    }
  },
  "ANALYSIS_DIFF_SCHEMA": {
    "name": "analysis_diff",
    "description": "Compare two analysis results.",
    "parameters": {
      "type": "object",
      "properties": {
        "report_a": {
          "type": "object",
          "description": "First analysis report dict."
        },
        "report_b": {
          "type": "object",
          "description": "Second analysis report dict."
        },
        "scope": {
          "type": "string",
          "description": "Scope label.",
          "default": ""
        },
        "format": {
          "type": "string",
          "enum": [
            "text",
            "json"
          ],
          "description": "Format: text or json.",
          "default": "text"
        }
      },
      "required": [
        "report_a",
        "report_b"
      ]
    }
  },
  "ANALYSIS_DUPLICATES_SCHEMA": {
    "name": "analysis_duplicates",
    "description": "Find duplicate code blocks via AST comparison.",
    "parameters": {
      "type": "object",
      "properties": {
        "path": {
          "type": "string",
          "description": "Absolute path to project or file."
        },
        "min_lines": {
          "type": "integer",
          "description": "Min lines (default: 5).",
          "default": 5
        },
        "similarity_threshold": {
          "type": "number",
          "description": "Similarity threshold (default: 0.8).",
          "default": 0.8
        },
        "top_n": {
          "type": "integer",
          "description": "Top N results (default: 10).",
          "default": 10
        }
      },
      "required": [
        "path"
      ]
    }
  },
  "ANALYSIS_FRAMEWORK_SCHEMA": {
    "name": "analysis_framework",
    "description": "Detect project technology stack automatically.",
    "parameters": {
      "type": "object",
      "properties": {
        "path": {
          "type": "string",
          "description": "Project root path."
        },
        "fast": {
          "type": "boolean",
          "description": "Fast mode (high-confidence only).",
          "default": false
        }
      },
      "required": [
        "path"
      ]
    }
  },
  "ANALYSIS_GRAPH_QUERY_SCHEMA": {
    "name": "analysis_graph_query",
    "description": "Query the project knowledge graph.",
    "parameters": {
      "type": "object",
      "properties": {
        "path": {
          "type": "string",
          "description": "Absolute path to project root."
        },
        "query": {
          "type": "string",
          "enum": [
            "callers",
            "callees",
            "hot_paths",
            "cycles",
            "health",
            "summary"
          ],
          "description": "Query type."
        },
        "symbol": {
          "type": "string",
          "description": "File or symbol for callers/callees."
        },
        "top_n": {
          "type": "integer",
          "description": "Max results (default: 10).",
          "default": 10
        },
        "force_reindex": {
          "type": "boolean",
          "description": "Force reindex before query (default: false).",
          "default": false
        }
      },
      "required": [
        "path",
        "query"
      ]
    }
  },
  "ANALYSIS_GRAPH_SCHEMA": {
    "name": "analysis_graph",
    "description": "Generate a Mermaid diagram from analysis results.",
    "parameters": {
      "type": "object",
      "properties": {
        "report": {
          "type": "object",
          "description": "Analysis report (from analysis_inspect/architecture/deadcode)."
        },
        "type": {
          "type": "string",
          "enum": [
            "dependency",
            "cycles",
            "summary"
          ],
          "description": "Graph type: dependency, cycles, summary.",
          "default": "dependency"
        }
      },
      "required": [
        "report"
      ]
    }
  },
  "ANALYSIS_INSPECT_SCHEMA": {
    "name": "analysis_inspect",
    "description": "Multi-step code analysis with configurable depth.",
    "parameters": {
      "type": "object",
      "properties": {
        "path": {
          "type": "string",
          "description": "File or directory path."
        },
        "symbol": {
          "type": "string",
          "description": "Optional symbol to focus on."
        },
        "depth": {
          "type": "integer",
          "description": "Analysis depth:\n  1: symbols + overview + diagnostics\n  2: + capsule + callers + callees\n  3: + call_hierarchy + type_hierarchy + highlight\n  4: + cycle_detector + dependency_graph + hot_paths\n  5: + blast_radius + unused_finder + complexity",
          "default": 2,
          "minimum": 1,
          "maximum": 5
        },
        "persist": {
          "type": "boolean",
          "description": "Persist results in Honcho (default: true).",
          "default": true
        }
      },
      "required": [
        "path"
      ]
    }
  },
  "ANALYSIS_MIGRATION_SCHEMA": {
    "name": "analysis_migration",
    "description": "Apply YAML-based bulk pattern migrations.",
    "parameters": {
      "type": "object",
      "properties": {
        "path": {
          "type": "string",
          "description": "Project root."
        },
        "rules": {
          "type": "array",
          "description": "List of migration rules. Each rule has: pattern + rewrite + optional file_glob/language/name.",
          "items": {
            "type": "object",
            "properties": {
              "pattern": {
                "type": "string",
                "description": "ast-grep pattern."
              },
              "rewrite": {
                "type": "string",
                "description": "Replacement template."
              },
              "file_glob": {
                "type": "string",
                "description": "File glob filter (default: **/*.ts)."
              },
              "language": {
                "type": "string",
                "description": "Language override."
              },
              "name": {
                "type": "string",
                "description": "Optional rule name."
              }
            },
            "required": [
              "pattern",
              "rewrite"
            ]
          }
        },
        "dry_run": {
          "type": "boolean",
          "description": "Preview changes without writing (default: true).",
          "default": true
        }
      },
      "required": [
        "path",
        "rules"
      ]
    }
  },
  "ANALYSIS_PATTERN_DISCOVER_SCHEMA": {
    "name": "analysis_pattern_discover",
    "description": "Discover code patterns not covered by existing rules.",
    "parameters": {
      "type": "object",
      "properties": {
        "path": {
          "type": "string",
          "description": "Absolute path to the project or directory to scan."
        },
        "scan_language": {
          "type": "string",
          "description": "Language filter (python, typescript, go).",
          "default": ""
        },
        "min_frequency": {
          "type": "integer",
          "description": "Min occurrences (default: 3).",
          "default": 3
        }
      },
      "required": [
        "path"
      ]
    }
  },
  "ANALYSIS_PERFORMANCE_SCHEMA": {
    "name": "analysis_performance",
    "description": "Find bottlenecks and complexity hotspots.",
    "parameters": {
      "type": "object",
      "properties": {
        "path": {
          "type": "string",
          "description": "File or directory path."
        },
        "persist": {
          "type": "boolean",
          "description": "Persist results in Honcho (default: true).",
          "default": true
        }
      },
      "required": [
        "path"
      ]
    }
  },
  "ANALYSIS_REPORT_SCHEMA": {
    "name": "analysis_report",
    "description": "Generate a structured analysis report.",
    "parameters": {
      "type": "object",
      "properties": {
        "scope": {
          "type": "string",
          "description": "Scope label."
        },
        "findings": {
          "type": "object",
          "description": "Key findings."
        },
        "recommendations": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Recommendations."
        },
        "persist": {
          "type": "boolean",
          "description": "Persist in Honcho (default: true).",
          "default": true
        }
      },
      "required": [
        "scope",
        "findings"
      ]
    }
  },
  "ANALYSIS_REVIEW_SCHEMA": {
    "name": "analysis_review",
    "description": "Automated code review between git refs.",
    "parameters": {
      "type": "object",
      "properties": {
        "path": {
          "type": "string",
          "description": "Absolute path to git repository."
        },
        "base": {
          "type": "string",
          "description": "Base branch (default: 'main').",
          "default": "main"
        },
        "head": {
          "type": "string",
          "description": "Head ref (default: current HEAD).",
          "default": "HEAD"
        },
        "max_files": {
          "type": "integer",
          "description": "Max files (default: 10).",
          "default": 10
        },
        "include_security": {
          "type": "boolean",
          "description": "Include security scan.",
          "default": true
        }
      },
      "required": [
        "path"
      ]
    }
  },
  "ANALYSIS_RISK_SCHEMA": {
    "name": "analysis_risk",
    "description": "Multi-factor risk assessment for a project.",
    "parameters": {
      "type": "object",
      "properties": {
        "path": {
          "type": "string",
          "description": "Absolute path to project directory."
        },
        "categories": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Risk categories to include (default: all). Options: dependencies, complexity, deadcode, security, hotspots, duplicates"
        }
      },
      "required": [
        "path"
      ]
    }
  },
  "ANALYSIS_SECURITY_SCHEMA": {
    "name": "analysis_security",
    "description": "Security analysis for vulnerabilities.",
    "parameters": {
      "type": "object",
      "properties": {
        "path": {
          "type": "string",
          "description": "Absolute path to file or directory to scan."
        },
        "kinds": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "errors",
              "vulnerabilities",
              "all"
            ]
          },
          "description": "What kinds of issues to scan for (default: ['all']).",
          "default": [
            "all"
          ]
        },
        "persist": {
          "type": "boolean",
          "description": "Persist results in Honcho (default: true).",
          "default": true
        }
      },
      "required": [
        "path"
      ]
    }
  },
  "ANALYSIS_TEST_INSIGHT_SCHEMA": {
    "name": "analysis_test_insight",
    "description": "Analyze test coverage for a symbol or project.",
    "parameters": {
      "type": "object",
      "properties": {
        "path": {
          "type": "string",
          "description": "Absolute path to file or directory."
        },
        "symbol": {
          "type": "string",
          "description": "Optional symbol name."
        },
        "generate": {
          "type": "boolean",
          "description": "Generate test scaffolds for untested symbols (default: false).",
          "default": false
        }
      },
      "required": [
        "path"
      ]
    }
  },
  "ANALYSIS_TIMELINE_SCHEMA": {
    "name": "analysis_timeline",
    "description": "Show symbol evolution across git history.",
    "parameters": {
      "type": "object",
      "properties": {
        "path": {
          "type": "string",
          "description": "Absolute file or directory path."
        },
        "symbol": {
          "type": "string",
          "description": "Optional symbol name (function/class) f\u00fcr fokussierte Timeline."
        },
        "max_commits": {
          "type": "integer",
          "description": "Max commits (default: 10).",
          "default": 10
        }
      },
      "required": [
        "path"
      ]
    }
  },
  "ANALYSIS_TREND_SCHEMA": {
    "name": "analysis_trend",
    "description": "Analysis trend over time via Honcho history.",
    "parameters": {
      "type": "object",
      "properties": {
        "scope": {
          "type": "string",
          "description": "Scope to analyze (e.g. 'path=src/', 'module:user-service'). Empty = all scopes.",
          "default": ""
        },
        "intent": {
          "type": "string",
          "enum": [
            "code",
            "architecture",
            "deadcode",
            "report",
            ""
          ],
          "description": "Filter by analysis intent. Empty = all intents.",
          "default": ""
        },
        "days": {
          "type": "integer",
          "description": "Days to look back (default: 30).",
          "default": 30,
          "minimum": 1,
          "maximum": 365
        }
      },
      "required": []
    }
  },
  "ANALYSIS_UI_GAP_SCHEMA": {
    "name": "analysis_ui_gap",
    "description": "UI Gap Analysis: compare backend vs frontend coverage.",
    "parameters": {
      "type": "object",
      "properties": {
        "path": {
          "type": "string",
          "description": "Absolute path to project root."
        },
        "format": {
          "type": "string",
          "enum": [
            "text",
            "json",
            "mermaid"
          ],
          "description": "Format: text or json.",
          "default": "text"
        },
        "include_storefront": {
          "type": "boolean",
          "description": "Include storefront routes in analysis (default: true).",
          "default": true
        },
        "include_admin": {
          "type": "boolean",
          "description": "Include admin routes in analysis (default: true).",
          "default": true
        }
      },
      "required": [
        "path"
      ]
    }
  },
  "ANALYSIS_WATCH_SCHEMA": {
    "name": "analysis_watch",
    "description": "Set up recurring code analysis.",
    "parameters": {
      "type": "object",
      "properties": {
        "path": {
          "type": "string",
          "description": "Path to watch."
        },
        "frequency": {
          "type": "string",
          "description": "Frequency: daily, hourly, or cron expr.",
          "default": "daily"
        },
        "depth": {
          "type": "integer",
          "description": "Analysis depth for inspect (1-5, default: 2).",
          "default": 2,
          "minimum": 1,
          "maximum": 5
        },
        "action": {
          "type": "string",
          "enum": [
            "create",
            "list",
            "remove"
          ],
          "description": "Action: create, list, remove.",
          "default": "create"
        },
        "name": {
          "type": "string",
          "description": "Watch name (required for remove). Auto-generated for create."
        }
      },
      "required": [
        "path"
      ]
    }
  },
  "ANALYSIS_UI_INSPECT_SCHEMA": {
    "name": "analysis_ui_inspect",
    "description": "UI element analysis via A11y tree and DOM inspection.",
    "parameters": {
      "type": "object",
      "properties": {
        "url": {
          "type": "string",
          "description": "URL to analyze."
        },
        "include_dom": {
          "type": "boolean",
          "description": "Include DOM inspection.",
          "default": true
        },
        "check_presence": {
          "type": "boolean",
          "description": "Check expected elements.",
          "default": false
        },
        "store_baseline": {
          "type": "boolean",
          "description": "Aktuellen Screenshot als Baseline speichern (fuer spaeteren Vergleich).",
          "default": false
        },
        "compare_baseline": {
          "type": "boolean",
          "description": "Mit gespeicherter Baseline vergleichen (Unterschiede erkennen).",
          "default": false
        }
      },
      "required": [
        "url"
      ]
    }
  }
}