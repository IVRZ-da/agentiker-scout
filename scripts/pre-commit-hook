#!/usr/bin/env python3
"""
Pre-commit hook für scout plugin.

Führt vor jedem Commit 12 Checks aus:
  ⚠️  Non-blocking (Warnings — kein Abbruch):
   1. Version-Consistency (plugin.yaml vs CHANGELOG.md vs pyproject.toml)
   2. YAML-Syntax (plugin.yaml)
   3. Large-File-Warnung (>1MB)
   4. CHANGELOG-Disziplin (Code geändert + CHANGELOG nicht aktualisiert)

  🔴  Blocking (brechen den Commit ab):
   5. Trailing Whitespace + Git-Conflict-Marker (git diff --cached --check)
   6. Merge-Conflict-Marker (dedizierter Scan: <<<<<<< ======= >>>>>>>)
   7. Secrets/Tokens/Private-Keys (Regex-Detection)
   8. Ruff Lint (F,E,T,W,I rules)
   9. Syntax-Fallback (ast.parse — nur wenn Ruff nicht verfügbar)
  10. Pytest (selektiv bei 1-2 Modulen, voll bei >2)
  11. Debug-Statement-Check (breakpoint, pdb, debugger)

Abbruch bei Fehlern in 7-11 (blocking) oder 12 (Tests).
1-6 sind Warnungen (kein Abbruch), 11 ist Fallback für 10.

Installation:
  git config core.hooksPath .githooks
  (Symlink .githooks/pre-commit -> ../scripts/pre-commit-hook existiert bereits)

Zum Überspringen:
  git commit --no-verify
  SKIP_PRECOMMIT=1 git commit -m "..."
"""

import os
import re
import subprocess
import sys

REPO_ROOT = os.path.dirname(os.path.dirname(os.path.abspath(__file__)))
VENV_PYTHON = os.environ.get("HERMES_PYTHON") or os.path.expanduser("~/.hermes/hermes-agent/venv/bin/python3")


# ── Utilities ──────────────────────────────────────────

def get_staged_files() -> list[str]:
    """Get list of staged file paths relative to REPO_ROOT."""
    result = subprocess.run(
        ["git", "diff", "--cached", "--name-only"],
        capture_output=True, text=True, timeout=10,
    )
    staged = result.stdout.strip().split("\n") if result.stdout.strip() else []
    return [s for s in staged if s]


def has_any(files: list[str], *suffixes: str) -> bool:
    """Check if any file ends with any of the given suffixes."""
    return any(f.endswith(suf) for f in files for suf in suffixes)


def run_cmd(cmd: list[str], timeout: int = 30, cwd: str | None = None) -> subprocess.CompletedProcess:
    """Run a command and return the CompletedProcess. Handles errors gracefully."""
    try:
        return subprocess.run(cmd, capture_output=True, text=True, timeout=timeout, cwd=cwd or REPO_ROOT)
    except FileNotFoundError:
        return subprocess.CompletedProcess(cmd, 127, "", f"Command not found: {cmd[0]}")
    except subprocess.TimeoutExpired:
        return subprocess.CompletedProcess(cmd, 124, "", f"Timeout after {timeout}s")


def print_header(text: str):
    """Print a section header."""
    print(f"\n── {text} ─{'─' * max(0, 60 - len(text))}")


# ── ⚠️  README Generator ──────────────────────────────

def run_readme_generator() -> bool:
    """Generate README.md from code. Blocking — fails commit if generator errors."""
    print("  📝 README generieren...", end=" ")
    r = run_cmd([VENV_PYTHON, "scripts/generate_readme.py"], timeout=60)
    if r.returncode == 0:
        print("✅")
        subprocess.run(
            ["git", "add", "README.md"],
            capture_output=True, timeout=10, cwd=REPO_ROOT,
        )
        return True
    else:
        print(f"❌\n  {r.stderr.strip() or r.stdout.strip()}")
        return False


# ── ⚠️  Version Consistency ───────────────────────────

def check_version_consistency() -> bool:
    """Check VERSION == plugin.yaml == pyproject.toml == CHANGELOG latest version. Non-blocking."""
    def extract_version(filepath: str, pattern: str) -> str | None:
        path = os.path.join(REPO_ROOT, filepath)
        if not os.path.exists(path):
            return None
        m = re.search(pattern, open(path).read())
        return m.group(1) if m else None

    versions = {
        "VERSION": extract_version("VERSION", r'([\d.]+)'),
        "plugin.yaml": extract_version("plugin.yaml", r'version:\s*([\d.]+)'),
        "pyproject.toml": extract_version("pyproject.toml", r'version\s*=\s*"([\d.]+)"'),
        "CHANGELOG.md": extract_version("CHANGELOG.md", r'^## \[?([\d.]+)\]?'),
    }

    unique = set(v for v in versions.values() if v)
    if len(unique) > 1:
        print("  ⚠️  Version Drift detected!")
        for file, ver in versions.items():
            print(f"      {file}: {ver}")
        return False
    else:
        ver = next(iter(unique), "?")
        print(f"  ✅ Version {ver} konsistent")
        return True


# ── ⚠️  Tag-Pflicht Check ────────────────────────────

def check_tag_exists(staged_files: list[str]) -> bool:
    """Wenn VERSION geändert wurde, prüfe ob ein passender Git-Tag existiert. Non-blocking."""
    if "VERSION" not in staged_files:
        return True
    version_path = os.path.join(REPO_ROOT, "VERSION")
    if not os.path.exists(version_path):
        return True
    version = open(version_path).read().strip()
    r = run_cmd(["git", "tag", "-l", f"v{version}"], timeout=5)
    if r.returncode == 0 and r.stdout.strip():
        print(f"  ✅ Tag v{version} existiert")
        _check_gh_release(version)
        return True
    print(f"  ⚠️  Kein Tag v{version} gefunden — vergessen zu taggen?")
    print(f"      → git tag v{version} && git push --tags")
    return True


def _check_gh_release(version: str) -> None:
    """Prüfe ob ein GitHub Release existiert. Non-blocking."""
    github_script = os.path.expanduser("~/.hermes/scripts/github-release.sh")
    if not os.path.exists(github_script):
        return
    r = run_cmd(["git", "remote", "get-url", "github"], timeout=5)
    if r.returncode != 0:
        return
    r = run_cmd(["bash", github_script, "--tag", f"v{version}", "--dry-run"], timeout=15)
    if r.returncode == 0:
        print(f"  ℹ️  GitHub Release v{version} bereit: bash ~/.hermes/scripts/github-release.sh")


# ── 🔴 Git Diff (Trailing Whitespace + basic conflicts) ─

def check_git_diff() -> bool:
    """Check for trailing whitespace and badly formatted merge conflict markers
    using git's built-in --check. Blocking if found."""
    r = run_cmd(["git", "diff", "--cached", "--check"], timeout=10)
    if r.returncode != 0:
        lines = r.stdout.strip().split("\n")
        print(f"  ␣  {len(lines)} Probleme gefunden (Trailing Whitespace / Merge Conflicts):")
        for line in lines[:15]:
            print(f"      {line}")
        if len(lines) > 15:
            print(f"      ... und {len(lines) - 15} weitere")
        return False
    return True


# ── 🔴 Merge Conflict Detection ───────────────────────


def check_merge_conflicts(staged_files: list[str]) -> bool:
    """Scan ALL staged files for unresolved merge conflict markers.
    Uses 'git show :<path>' to inspect the staged content.
    Blocking if found.

    False-positive-safe: '=======' (exactly 7 '=') is the git conflict separator.
    Longer '====...' lines (tables, section headers) are NOT detected.
    '<<<<<<< refname' matches when line STARTS WITH '<<<<<<< ' (7 '<' + space).
    '>>>>>>> refname' matches when line STARTS WITH '>>>>>>> ' (7 '>' + space).
    """
    issues: list[str] = []
    for sf in staged_files:
        if not sf.strip():
            continue
        r = run_cmd(["git", "show", f":{sf}"], timeout=10)
        if r.returncode != 0:
            continue
        content_bytes = r.stdout.encode('utf-8', errors='replace') if not isinstance(r.stdout, bytes) else r.stdout
        lines = content_bytes.split(b'\n')
        for i, line in enumerate(lines, 1):
            stripped = line.strip()
            if not stripped:
                continue
            # '=======' (exactly 7 '=') is the git conflict separator
            if stripped == b'=======':
                issues.append(f"  {sf}:{i}")
                break
            # '<<<<<<< refname' — starts with 7 '<' + space
            if stripped.startswith(b'<<<<<<< '):
                issues.append(f"  {sf}:{i}")
                break
            # '>>>>>>> refname' — starts with 7 '>' + space
            if stripped.startswith(b'>>>>>>> '):
                issues.append(f"  {sf}:{i}")
                break

    if issues:
        print(f"  🔀 Merge-Conflicts in {len(issues)} Datei(en):")
        for i in issues:
            print(f"      {i}")
        print("  → Konflikte auflösen, dann Commit wiederholen.")
        return False
    return True


# ── 🔴 Secret Detection ───────────────────────────────

SECRET_PATTERNS: list[tuple[str, str, bool]] = [
    # (pattern, description, blocking)
    # 🔴 High-confidence (always block)
    (r'-----BEGIN\s+(?:RSA|EC|DSA|OPENSSH)\s+PRIVATE KEY-----', 'Private/SSH Key', True),
    (r'-----BEGIN\s+CERTIFICATE-----', 'Certificate', True),

    # 🔴 Medium-confidence (block if not in tests/dummy files)
    (r'sk-[a-zA-Z0-9]{20,}', 'OpenAI API Key (sk-...)', False),
    (r'(?i)(?:gh[ps]_|github_pat_)[a-zA-Z0-9]{36,}', 'GitHub Token', False),
    (r'AKIA[0-9A-Z]{16}', 'AWS Access Key ID', False),
    (r'(?i)(?:postgres|mysql|redis|mongodb|sqlite)://\w+:\w+@', 'DB connection string with credentials', False),
    (r'eyJ[a-zA-Z0-9_-]{10,}\.[a-zA-Z0-9_-]{10,}\.[a-zA-Z0-9_-]{10,}', 'JWT Token', False),

    # Dynamic credential assignments (could be false-positive)
    (r'(?i)(?:password|passwd|pwd|secret|token|api[_-]?key)\s*[:=]\s*["\'][A-Za-z0-9_@#$%^&+=!]{12,}', 'Credential assignment', False),
]


def check_secrets(staged_files: list[str]) -> bool:
    """Scan staged files for accidentally committed secrets, keys, and tokens.
    Uses git show to inspect staged content (not working tree). Blocking for high-confidence matches.
    Skips the hook script itself (contains pattern definitions)."""
    all_ok = True
    has_high_confidence = False
    findings: list[str] = []

    for sf in staged_files:
        if not sf.strip():
            continue

        # Skip the hook script itself — it contains pattern definitions
        if sf == 'scripts/pre-commit-hook':
            continue

        # Skip binary-like extensions
        ext = os.path.splitext(sf)[1].lower()
        if ext in ('.png', '.jpg', '.jpeg', '.gif', '.ico', '.svg', '.woff', '.woff2', '.ttf', '.eot', '.pdf', '.zip', '.tar', '.gz', '.lock'):
            continue

        r = run_cmd(["git", "show", f":{sf}"], timeout=10)
        if r.returncode != 0 or not r.stdout.strip():
            continue

        # Make sure we don't flag test fixtures or dummy data
        is_test_file = '/tests/' in sf or sf.startswith('tests/') or '/test_' in sf or sf.startswith('test_')
        is_fixture = '/fixtures/' in sf or '/mock/' in sf or '/__snapshots__/' in sf

        for pattern, description, blocking in SECRET_PATTERNS:
            # Skip test/fixture files for dynamic credential patterns (too many false positives)
            if (is_test_file or is_fixture) and not blocking:
                continue

            matches = list(re.finditer(pattern, r.stdout))
            if matches:
                for m in matches:
                    start = max(0, m.start() - 20)
                    end = min(len(r.stdout), m.end() + 20)
                    context = r.stdout[start:end].replace('\n', '\\n')
                    findings.append(
                        f"  {'🔴' if blocking else '⚠️'} {description} in {sf}:\n"
                        f"      ...{context}..."
                    )
                    if blocking:
                        has_high_confidence = True

    if findings:
        print("  🛡️  Secret Scanner:")
        for f in findings:
            print(f)
        if has_high_confidence:
            print("  → Commit abgebrochen — Secrets mit hoher Konfidenz gefunden!")
            all_ok = False
        else:
            print("  → ⚠️  Bitte prüfen — sind das echte Secrets oder Dummy-Daten?")
            print("     (git commit --no-verify zum Überspringen)")
    return all_ok


# ── 🔴 Ruff Lint (replace ast.parse) ──────────────────

def ruff_check(py_files: list[str]) -> bool:
    """Run ruff check on staged .py files using F, E, T, W rule sets.
    Blocking if any issues found. Falls back to check_syntax() if ruff unavailable."""
    if not py_files:
        return True

    # Check ruff availability
    r_which = run_cmd([VENV_PYTHON, "-m", "ruff", "--version"], timeout=10)
    if r_which.returncode != 0:
        print("  ⚠️  Ruff nicht verfügbar — verwende Syntax-Check-Fallback")
        return check_syntax(py_files)

    print("  🔍 Ruff Lint (F,E,T,W)...")
    all_ok = True
    for pf in py_files:
        full_path = os.path.join(REPO_ROOT, pf)
        if not os.path.exists(full_path):
            continue

        # Determine rules: scripts/ use print() as CLI output, skip T201
        is_script = pf.startswith("scripts/")
        select_rules = "F,E,W,I" if is_script else "F,E,T,W,I"

        r = run_cmd(
            [VENV_PYTHON, "-m", "ruff", "check",
             "--select", select_rules,
             "--ignore", "E501,F403,F405",
             "--no-cache",
             full_path],
            timeout=30,
        )

        if r.returncode != 0:
            all_ok = False
            issues = [l for l in r.stdout.strip().split('\n') if l.strip() and pf in l]
            if issues:
                print(f"\n  ❌ {pf}:")
                for issue in issues[:10]:
                    # Clean up ruff output — remove full path prefix for readability
                    display = issue.replace(full_path, pf)
                    print(f"      {display}")
                if len(issues) > 10:
                    print(f"      ... und {len(issues)-10} weitere")

    if all_ok:
        print("  ✅ Ruff: keine Probleme")
    else:
        print("  → Commit abgebrochen — Ruff-Fehler beheben.")
    return all_ok


# ── 🔴 Syntax Fallback ─────────────────────────────────

def check_syntax(py_files: list[str]) -> bool:
    """Python AST syntax check. Only used as fallback if ruff is unavailable."""
    if not py_files:
        return True
    print("  📝 Syntax-Check (Fallback)...", end=" ")
    all_ok = True
    for pf in py_files:
        full_path = os.path.join(REPO_ROOT, pf)
        if os.path.exists(full_path):
            r = run_cmd(
                [VENV_PYTHON, "-c", f"import ast; ast.parse(open('{full_path}').read())"],
                timeout=10,
            )
            if r.returncode != 0:
                print(f"❌\n  Syntaxfehler in {pf}: {r.stderr.strip()}")
                all_ok = False
    if all_ok:
        print("✅")
    return all_ok


# ── 🔴 Debug-Statement-Check (blocking) ──────────────────

def check_debug_statements(staged_files: list[str]) -> bool:
    """Scan staged files for debug statements (breakpoint, pdb, debugger). Blocking."""
    debug_patterns = [
        (r"breakpoint\(\)", "breakpoint()"),
        (r"pdb\.set_trace\(\)", "pdb.set_trace()"),
        (r"debugger;?", "debugger statement"),
        (r"import pdb", "import pdb"),
    ]
    issues = []
    for sf in staged_files:
        if not sf.endswith((".py", ".ts", ".tsx", ".js", ".jsx")):
            continue
        full_path = os.path.join(REPO_ROOT, sf)
        if not os.path.exists(full_path):
            continue
        try:
            with open(full_path, "rb") as f:
                content = f.read()
            for pat, desc in debug_patterns:
                if re.search(pat.encode(), content):
                    issues.append(f"  ❌ {sf}: {desc} gefunden")
                    break
        except Exception:
            continue
    if issues:
        for i in issues:
            print(i)
        return False
    return True


# ── ⚠️  TODO/FIXME Warnung (non-blocking) ────────────────

def check_todo_fixme(staged_files: list[str]) -> bool:
    """Warn when staged files contain TODO/FIXME comments. Non-blocking."""
    todo_pattern = rb"(TODO|FIXME|HACK|XXX|WORKAROUND|KNOWN.?BUG)"
    issues = []
    for sf in staged_files:
        if sf == "scripts/pre-commit-hook":
            continue
        full_path = os.path.join(REPO_ROOT, sf)
        if not os.path.exists(full_path):
            continue
        try:
            with open(full_path, "rb") as f:
                content = f.read()
            matches = re.findall(todo_pattern, content)
            if matches:
                unique = set()
                for m in matches:
                    m_str = m if isinstance(m, bytes) else m[0]
                    if isinstance(m_str, bytes):
                        m_str = m_str.decode("ascii", errors="replace")
                    unique.add(m_str.upper())
                issues.append(f"  ⚠️  {sf}: {', '.join(sorted(unique))} gefunden")
        except Exception:
            continue
    if issues:
        print("  ⚠️  TODO/FIXME Markierungen im Code:")
        for i in issues:
            print(f"     {i}")
        return False
    return True


# ── ⚠️  YAML Validation ────────────────────────────────

def check_yaml_files(staged_files: list[str]) -> bool:
    """Validate staged .yaml/.yml files for syntax errors. Non-blocking."""
    yaml_files = [f for f in staged_files if f.endswith(('.yaml', '.yml'))]
    if not yaml_files:
        return True

    # Check pyyaml availability
    r_check = run_cmd([VENV_PYTHON, "-c", "import yaml; print('ok')"], timeout=5)
    if r_check.returncode != 0:
        return True  # Skip if pyyaml not available — non-blocking

    issues: list[str] = []
    for yf in yaml_files:
        full_path = os.path.join(REPO_ROOT, yf)
        if not os.path.exists(full_path):
            continue
        r = run_cmd(
            [VENV_PYTHON, "-c", f"import yaml; yaml.safe_load(open('{full_path}'))"],
            timeout=10,
        )
        if r.returncode != 0:
            err = r.stderr.strip().split('\n')[-1] if r.stderr.strip() else 'unknown error'
            issues.append(f"      {yf}: {err}")

    if issues:
        print("  ⚠️  YAML-Syntax-Fehler:")
        for i in issues:
            print(i)
        return False
    return True


# ── ⚠️  TOML Validation ───────────────────────────────

def check_toml_files(staged_files: list[str]) -> bool:
    """Validate pyproject.toml for syntax errors. Non-blocking.
    Uses tomllib (Python 3.11+ stdlib)."""
    toml_files = [f for f in staged_files if f == 'pyproject.toml']
    if not toml_files:
        return True

    # Check tomllib availability (Python 3.11+)
    r_check = run_cmd([VENV_PYTHON, "-c", "import tomllib; print('ok')"], timeout=5)
    if r_check.returncode != 0:
        # Python < 3.11 — try tomli
        r_check2 = run_cmd([VENV_PYTHON, "-c", "import tomli; print('ok')"], timeout=5)
        if r_check2.returncode != 0:
            return True  # Skip if neither available

    for tf in toml_files:
        full_path = os.path.join(REPO_ROOT, tf)
        if not os.path.exists(full_path):
            continue
        r = run_cmd(
            [VENV_PYTHON, "-c",
             f"import tomllib; tomllib.load(open('{full_path}', 'rb'))"],
            timeout=10,
        )
        if r.returncode != 0:
            # Try tomli as fallback
            r = run_cmd(
                [VENV_PYTHON, "-c",
                 f"import tomli; tomli.load(open('{full_path}', 'rb'))"],
                timeout=10,
            )
        if r.returncode != 0:
            err = r.stderr.strip().split('\n')[-1] if r.stderr.strip() else 'unknown error'
            print(f"  ⚠️  TOML-Syntax-Fehler in {tf}: {err}")
            return False
    return True


# ── ⚠️  Large File Warning ────────────────────────────

LARGE_FILE_THRESHOLD = 1_000_000  # 1MB


def check_file_sizes(staged_files: list[str]) -> bool:
    """Warn when staged files exceed 1MB. Non-blocking."""
    large: list[tuple[str, int]] = []
    for f in staged_files:
        fp = os.path.join(REPO_ROOT, f)
        if os.path.isfile(fp):
            size = os.path.getsize(fp)
            if size > LARGE_FILE_THRESHOLD:
                large.append((f, size))

    if large:
        print("  ⚠️  Large Files:")
        for name, size in large:
            print(f"      {name} ({size // 1024} KB)")
        print("     → Gehören große Dateien wirklich ins Git-Repo?")
        # Non-blocking — just warn
    return True


# ── ⚠️  CHANGELOG Discipline ─────────────────────────

def check_changelog(staged_files: list[str]) -> bool:
    """Warn when .py files are changed but CHANGELOG.md is not.
    Non-blocking — but worth noting to prevent changelog drift."""
    py_changed = any(f.endswith('.py') for f in staged_files)
    changelog_changed = any(f == 'CHANGELOG.md' for f in staged_files)

    if py_changed and not changelog_changed:
        print("  ⚠️  Code geändert aber CHANGELOG.md nicht aktualisiert")
        print("     → Bitte Eintrag in CHANGELOG.md ergänzen!")
        return False
    return True


