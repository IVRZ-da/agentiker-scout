    "shared/honcho.py": ["test_analysis/analysis_core"],
    "shared/__init__.py": ["test_analysis/analysis_core"],
    "shared/framework_detector.py": ["test_framework_detector"],
    "shared/pattern_loader.py": ["test_pattern_loader"],
    "shared/yaml_rule_loader.py": ["test_yaml_rule_loader"],
    "shared/dependency_scanner.py": ["test_dependency_scanner"],
    "shared/registry.py": ["test_analysis/analysis_core"],
    # Core modules
    "__init__.py": ["test_bughunt/structure", "test_auto_discovery"],
    "_fmt.py": ["test_analysis/fmt", "test_bughunt/tools_basic"],
    # Scripts / config
    "conftest.py": [],
    "pyproject.toml": ["all"],
    "scripts/pre-commit-hook": [],
}

# Threshold: wenn mehr als N Module geändert, volle Test-Suite
# Erhöht von 2 auf 6
MODULE_CHANGE_THRESHOLD = 6


def determine_test_files(staged_files: list[str]) -> list[str]:
    """Determine which test files to run based on changed modules.

    - If a test file itself changed → run only that test file
    - If ≤ MODULE_CHANGE_THRESHOLD modules changed → run matching tests
    - If > MODULE_CHANGE_THRESHOLD modules changed → run all tests
    """
    staged_tests = [f for f in staged_files if f.startswith("tests/") and f.endswith(".py")]
    changed_modules = set()

    # First pass: check if test files themselves changed
    if staged_tests:
        return staged_tests

    # Second pass: map source modules to test files
    for f in staged_files:
        f = f.replace("\\", "/")
        for module in MODULE_TEST_MAP:
            if f == module or f.endswith("/" + module):
                changed_modules.add(module)

    if not changed_modules:
        return []  # No code changes — skip tests

    # If threshold exceeded, run all tests
    if len(changed_modules) > MODULE_CHANGE_THRESHOLD:
        return ["all"]

    test_files = []
    for mod in changed_modules:
        for tf in MODULE_TEST_MAP.get(mod, []):
            if tf == "all":
                return ["all"]
            test_file = f"tests/{tf}.py"
            if os.path.exists(os.path.join(REPO_ROOT, test_file)):
                test_files.append(test_file)

    # Deduplicate while preserving order
    seen = set()
    unique_test_files = []
    for tf in test_files:
        if tf not in seen:
            seen.add(tf)
            unique_test_files.append(tf)

    return unique_test_files or ["all"]


def run_tests(test_files: list[str]) -> bool:
    """Run pytest on given test files. Returns True if all pass."""
    if not test_files:
        print("  🧪 Keine Code-Änderungen — Tests übersprungen")
        return True

    label = "alle Tests" if test_files == ["all"] else f"{len(test_files)} Testdateien"
    print(f"  🧪 {label}...")

    args = [VENV_PYTHON, "-m", "pytest", "-q", "--tb=line", "-x"]
    if test_files != ["all"]:
        args.extend(test_files)

    env = {**os.environ, "PYTHONPATH": os.path.expanduser("~/.hermes/plugins")}
    r = run_cmd(args, timeout=120, cwd=REPO_ROOT)

    if r.returncode == 0:
        summary = [l for l in r.stdout.strip().split("\n") if "passed" in l]
        print(f"  ✅ Tests bestanden ({summary[-1] if summary else 'OK'})")
        return True
    else:
        failures = [l for l in (r.stderr or "").strip().split("\n") if "FAILED" in l]
        print(f"  ❌ {len(failures)} Test(s) fehlgeschlagen:")
        for f in failures[:10]:
            print(f"     {f}")
        print("\n  Commit abgebrochen — Fehler beheben vor erneutem Commit.")
        print("  (git commit --no-verify zum Überspringen)")
        return False


# ── Main ──────────────────────────────────────────────

def check_coverage() -> bool:
    """Run coverage check with fail-under threshold. Returns True if coverage check passes."""
    print(f"  📊 Coverage-Gate...")
    cov_config = os.path.join(REPO_ROOT, ".coveragerc")
    if not os.path.exists(cov_config):
        print(f"  ⚠️  Keine .coveragerc gefunden — Coverage-Gate übersprungen")
        return True

    args = [VENV_PYTHON, "-m", "pytest", "-q", "--tb=line",
            "--cov", "--cov-config=" + cov_config, "--cov-fail-under=69"]
    env = {**os.environ, "PYTHONPATH": os.path.expanduser("~/.hermes/plugins")}
    r = run_cmd(args, timeout=180, cwd=REPO_ROOT)

    if r.returncode == 0:
        print(f"  ✅ Coverage-Gate bestanden (≥81%)")
        return True
    else:
        print(f"  ❌ Coverage unter 81% — Commit abgebrochen")
        print(f"  (git commit --no-verify zum Überspringen)")
        return False


def main():
    os.chdir(REPO_ROOT)

    # ── CLI Flags ───────────────────────────────────────
    import sys as _sys
    dry_run = "--dry-run" in _sys.argv
    health_check = "--health" in _sys.argv

    if health_check:
        print("🔍 Pre-Commit-Hook Health Check")
        print(f"  Repository: {REPO_ROOT}")
        print(f"  Venv Python: {VENV_PYTHON}")
        # Check ruff
        r = run_cmd([VENV_PYTHON, "-m", "ruff", "--version"], timeout=5)
        print(f"  Ruff: {'✅' if r.returncode == 0 else '❌'} {r.stdout.strip()[:40] if r.stdout.strip() else 'nicht verfügbar'}")
        # Check pyyaml
        r = run_cmd([VENV_PYTHON, "-c", "import yaml; print(yaml.__version__)"], timeout=5)
        print(f"  PyYAML: {'✅' if r.returncode == 0 else '❌'} {r.stdout.strip() if r.stdout.strip() else 'nicht verfügbar'}")
        # Check tomllib
        r = run_cmd([VENV_PYTHON, "-c", "import tomllib; print('ok')"], timeout=5)
        print(f"  tomllib: {'✅' if r.returncode == 0 else '❌'} (Python ≥3.11)")
        # Check git
        r = run_cmd(["git", "--version"], timeout=5)
        print(f"  Git: {'✅' if r.returncode == 0 else '❌'} {r.stdout.strip()}")
        # Check hooksPath
        r = run_cmd(["git", "config", "core.hooksPath"], timeout=5)
        print(f"  hooksPath: {r.stdout.strip() if r.returncode == 0 else '❌ nicht gesetzt'}")
        # Check tests
        r = run_cmd([VENV_PYTHON, "-m", "pytest", "--version"], timeout=5)
        print(f"  Pytest: {'✅' if r.returncode == 0 else '❌'} {r.stdout.strip()[:40]}")
        # Check MODULE_TEST_MAP
        print(f"  MODULE_TEST_MAP: {len(MODULE_TEST_MAP)} Module mapped")
        for mod, tests in sorted(MODULE_TEST_MAP.items()):
            print(f"    {mod} → {', '.join(tests) if tests else '(keine Tests)'}")
        return 0

    staged = get_staged_files()

    if not staged and not dry_run:
        print("🔍 Keine staged Dateien — überspringe Pre-Commit-Checks")
        return 0

    # Allow override via SKIP_PRECOMMIT env var
    if os.environ.get("SKIP_PRECOMMIT"):
        print("🔍 SKIP_PRECOMMIT gesetzt — überspringe Pre-Commit-Checks")
        return 0

    start_time = __import__("time").time()

    n_staged = len(staged)
    print(f"🔍 Pre-Commit-Check: {n_staged} Datei{'en' if n_staged != 1 else ''} staged" + (" (dry-run)" if dry_run else ""))

    only_docs = not has_any(staged, ".py")
    py_files = [f for f in staged if f.endswith(".py")]

    print_header("⚠️  Warnings (non-blocking)")

    # 1. Version-Consistency-Check (immer)
    check_version_consistency()

    # 1b. Tag-Pflicht-Check (wenn VERSION staged)
    check_tag_exists(staged)

    # 2-3. Config-Validation (YAML + TOML, nur wenn geändert)
    check_yaml_files(staged)
    check_toml_files(staged)

    # 5. Large-Files
    check_file_sizes(staged)

    # 6. CHANGELOG-Disziplin
    check_changelog(staged)
    check_todo_fixme(staged)

    print_header("🔴 Blocking Checks")

    # 7. Git Diff (trailing whitespace + basic conflict markers)
    if not check_git_diff():
        return 1

    # 8. Merge-Conflict-Marker Scan
    if not check_merge_conflicts(staged):
        return 1

    # 9. Secret Detection
    if not check_secrets(staged):
        return 1

    # 11. Debug-Statement-Check (blocking)
    if not check_debug_statements(staged):
        return 1

    # 10. Ruff Lint (replaces syntax-check)
    if not ruff_check(py_files):
        return 1

    # Bei nur Docs: hier aufhören (keine Tests)
    if only_docs:
        # Trotzdem README-Tool-Tabelle prüfen wenn README.md gestaged
        _check_readme_tools(staged, REPO_ROOT)
        print("  📄 Nur Dokumentation geändert — Tests übersprungen")
        return 0

    print_header("🧪 Tests")

    # 12. Tests
    test_files = determine_test_files(staged)
    if not run_tests(test_files):
        return 1

    # 13. Coverage Gate (nur bei vollem Test-Suite)
    if test_files == ["all"] and not check_coverage():
        return 1

    print(f"\n✅ Alle 12 Pre-Commit-Checks bestanden")
    elapsed = __import__("time").time() - (start_time if "start_time" in dir() else __import__("time").time())
    print(f"⏱️  Dauer: {elapsed:.1f}s")
    return 0


def _check_readme_tools(staged: list[str], repo_root: str) -> bool:
    """Auto-generate README using the per-plugin generate_readme.py."""
    if not any(f.endswith((".py", "README.md")) for f in staged):
        return True
    gen_script = os.path.join(repo_root, "scripts/generate_readme.py")
    if not os.path.exists(gen_script):
        return True
    readme_path = os.path.join(repo_root, "README.md")
    if not os.path.exists(readme_path):
        return True
    try:
        r = run_cmd([VENV_PYTHON, gen_script], timeout=30)
        if r.returncode == 0:
            subprocess.run(
                ["git", "add", "README.md"],
                capture_output=True, timeout=10, cwd=repo_root,
            )
            return True
    except Exception:
        pass
    return True


if __name__ == "__main__":
    sys.exit(main())
